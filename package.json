{
  "name": "pody-rss-validator",
  "version": "0.1.0",
  "description": "Validate any podcast RSS feed against Apple Podcasts, Spotify for Creators, Amazon Music, and Podcasting 2.0 in one command",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pody-rss-validator": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test test/",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "podcast",
    "rss",
    "validator",
    "apple-podcasts",
    "spotify",
    "amazon-music",
    "podcasting-2.0",
    "cli"
  ],
  "author": "Aviv Charuvi <aviv@pody.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avivcha/pody-rss-validator.git"
  },
  "homepage": "https://github.com/Avivcha/pody-rss-validator#readme",
  "bugs": {
    "url": "https://github.com/Avivcha/pody-rss-validator/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
